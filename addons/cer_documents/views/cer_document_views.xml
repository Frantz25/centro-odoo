<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_cer_document_list" model="ir.ui.view">
    <field name="name">cer.document.list</field>
    <field name="model">cer.document</field>
    <field name="arch" type="xml">
      <list>
        <field name="number"/>
        <field name="name"/>
        <field name="template_id"/>
        <field name="res_model"/>
        <field name="res_id"/>
        <field name="state"/>
        <field name="create_date"/>
      </list>
    </field>
  </record>

  <record id="view_cer_document_form" model="ir.ui.view">
    <field name="name">cer.document.form</field>
    <field name="model">cer.document</field>
    <field name="arch" type="xml">
      <form string="Documento CER">
        <header>
          <button name="action_generate" type="object" string="Regenerar" class="btn-secondary"/>
          <button name="action_print_pdf" type="object" string="Imprimir PDF" class="btn-primary"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,final"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="number" readonly="1"/>
              <field name="name"/>
              <field name="company_id"/>
              <field name="template_id"/>
            </group>
            <group>
              <field name="res_model" readonly="1"/>
              <field name="res_id" readonly="1"/>
              <field name="res_ref" readonly="1"/>
            </group>
          </group>
          <notebook>
            <page string="Contenido">
              <field name="html_content" widget="html" readonly="1"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_cer_documents" model="ir.actions.act_window">
    <field name="name">Documentos</field>
    <field name="res_model">cer.document</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
