<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
  <record id="cer_document_template_comercial" model="cer.document.template">
    <field name="active">True</field>
    <field name="name">Plantilla Comercial CER</field>
    <field name="model_id" ref="sale.model_sale_order"/>
    <field name="body_html" type="html"><![CDATA[
<div>
  <h3 style="margin-bottom:8px;">Cotización / Reserva CER</h3>
  <p><strong>Cliente:</strong> {{partner_id.name}}</p>
  <p><strong>Documento:</strong> {{name}}</p>
  <p><strong>Fecha:</strong> {{date_order}}</p>
  <p><strong>Total:</strong> {{amount_total}}</p>
  <p><strong>Vigencia:</strong> 7 días</p>
</div>
    ]]></field>
    <field name="note">Plantilla comercial base para documentos CER.</field>
  </record>

  <record id="cer_document_template_reserva_checkin" model="cer.document.template">
    <field name="active">True</field>
    <field name="name">Plantilla Reserva / Check-in CER</field>
    <field name="model_id" ref="sale.model_sale_order"/>
    <field name="body_html" type="html"><![CDATA[
<div>
  <h3 style="margin-bottom:8px;">Comprobante de Reserva</h3>
  <p><strong>Cliente:</strong> {{partner_id.name}}</p>
  <p><strong>N° Reserva:</strong> {{cer_booking_name}}</p>
  <p><strong>Entrada:</strong> {{cer_date_from}}</p>
  <p><strong>Salida:</strong> {{cer_date_to}}</p>
  <p><strong>Participantes:</strong> {{cer_participants}}</p>
</div>
    ]]></field>
    <field name="note">Plantilla base para confirmación y recepción/check-in.</field>
  </record>

  <record id="cer_document_template_acta_aceptacion" model="cer.document.template">
    <field name="active">True</field>
    <field name="name">Plantilla Acta de Aceptación CER</field>
    <field name="model_id" ref="sale.model_sale_order"/>
    <field name="body_html" type="html"><![CDATA[
<div>
  <h3 style="margin-bottom:8px;">Acta de Aceptación</h3>
  <p>Yo, <strong>{{partner_id.name}}</strong>, declaro aceptar las condiciones de la reserva indicada.</p>
  <p><strong>Documento:</strong> {{name}}</p>
  <p><strong>Fecha:</strong> {{date_order}}</p>
  <p style="margin-top:24px;">Firma: ________________________________</p>
</div>
    ]]></field>
    <field name="note">Base legal inicial; la firma PNG se incorpora en iteración de portal/acta.</field>
  </record>
</odoo>
