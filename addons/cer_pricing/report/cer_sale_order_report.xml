<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_saleorder_document_inherit_cer_pricing" inherit_id="sale.report_saleorder_document">
    <xpath expr="/t" position="replace">
      <t t-foreach="docs" t-as="order">
        <t t-call="web.external_layout">
<div class="page">
          <!-- Encabezado CER -->
          <div class="mt-2 mb-2">
            <t t-if="order._fields.get('cer_date_from') and order.cer_date_from">
              <div><strong>Fecha Entrada</strong>: <span t-field="order.cer_date_from"/></div>
            </t>
            <t t-if="order._fields.get('cer_date_to') and order.cer_date_to">
              <div><strong>Fecha Salida</strong>: <span t-field="order.cer_date_to"/></div>
            </t>
            <t t-if="order._fields.get('cer_stay_display') and order.cer_stay_display">
              <div><strong>Estadía</strong>: <span t-esc="order.cer_stay_display"/></div>
            </t>
            <t t-if="order._fields.get('cer_participants') and order.cer_participants">
              <div><strong>Participantes</strong>: <span t-esc="order.cer_participants"/></div>
            </t>
            <t t-if="order._fields.get('cer_discount_id') and order.cer_discount_id">
              <div><strong>Descuento</strong>: <span t-esc="str(order.cer_discount_id.discount_percent) + '%'"/></div>
            </t>
          </div>

          <!-- Tabla CER -->
          <table class="table table-sm o_main_table">
            <thead>
              <tr>
                <th class="text-start">DESCRIPCIÓN</th>
                <th class="text-end">CANTIDAD DE PERSONAS</th>
                <th class="text-end">NOCHES Y/O DÍAS</th>
                <th class="text-end">PRECIO UNITARIO</th>
                <th class="text-end">PRECIO TOTAL</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="order.order_line" t-as="l">
                <t t-if="l.display_type == 'line_section'">
                  <tr class="o_line_section">
                    <td colspan="5"><strong t-field="l.name"/></td>
                  </tr>
                </t>
                <t t-elif="l.display_type == 'line_note'">
                  <tr class="o_line_note">
                    <td colspan="5"><em t-field="l.name"/></td>
                  </tr>
                </t>
                <t t-else="">
                  <tr>
                    <td class="text-start"><span t-field="l.name"/></td>
                    <td class="text-end"><span t-esc="l.cer_participants or ''"/></td>
                    <td class="text-end"><span t-esc="l.cer_duration_display or ''"/></td>
                    <td class="text-end"><span t-field="l.cer_price_unit_excl_tax"/></td>
                    <td class="text-end"><span t-field="l.price_total"/></td>
                  </tr>
                </t>
              </t>
            </tbody>
          </table>

          <!-- Totales: reusar bloque estándar -->
          <t t-call="sale.report_saleorder_totals"/>
        </div>
        </t>
      </t>
    </xpath>
  </template>
</odoo>
